<!DOCTYPE html>
<html>

<head>

<title>Portal Data Kota Tangerang</title>

<link rel="stylesheet" href="/css/style.css">

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

</head>

<body>


<nav class="navbar navbar-dark">

<div class="container">

<span class="navbar-brand">

📊 Portal Data Kota Tangerang

</span>

</div>

</nav>


<section class="hero">

<h1>Portal Data Terbuka Kota Tangerang</h1>

<p>Akses dataset pemerintah secara transparan</p>

</section>


<div class="container mt-5">

<input id="search" class="form-control" placeholder="Cari dataset..." onkeyup="searchDataset()">

</div>


<div class="container mt-5">

<div class="row">

<% datasets.forEach(function(d){ %>

<div class="col-md-4 mb-4 dataset-item">

<div class="card dataset-card">

<div class="card-body text-center">

<div class="dataset-icon">📁</div>

<h5><%= d %></h5>

<a href="/dataset/<%= d %>" class="btn btn-primary">

Lihat

</a>

</div>

</div>

</div>

<% }) %>

</div>

</div>


<div class="footer">

Portal Data Kota Tangerang

</div>


<script src="/js/search.js"></script>

</body>

</html>