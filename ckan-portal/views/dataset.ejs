<!DOCTYPE html>
<html>

<head>

<title><%= dataset.title %></title>

<link rel="stylesheet" href="/css/style.css">

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

</head>

<body>


<div class="hero">

<h1><%= dataset.title %></h1>

<p><%= dataset.notes %></p>

</div>


<div class="container mt-5">

<h3>Resources</h3>

<div class="row">

<% dataset.resources.forEach(function(r){ %>

<div class="col-md-4">

<div class="card mb-4">

<div class="card-body text-center">

<h5><%= r.name %></h5>

<a href="/preview/<%= r.id %>" class="btn btn-success">

Preview

</a>

<a href="<%= r.url %>" class="btn btn-primary">

Download

</a>

</div>

</div>

</div>

<% }) %>

</div>

</div>

</body>

</html>